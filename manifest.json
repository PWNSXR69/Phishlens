{
  "manifest_version": 3,
  "name": "PhishLens",
  "version": "0.1.0",
  "description": "Real-time phishing detection: lookalike domains, suspicious redirects, and credential-stealing forms.",

  "permissions": [
    "webNavigation",
    "storage",
    "activeTab",
    "scripting",
    "notifications"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/similarity.js", "lib/brands.js", "lib/domain.js", "content.js"],
      "run_at": "document_end"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishLens"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
